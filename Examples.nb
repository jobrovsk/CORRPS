      FrameMargins->0,
      ImageSize->Automatic],
     DynamicModuleValues:>{}],
    BaseStyle->"InformationGridFrame",
    StripOnInput->False], "InformationGridPlain",
   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "(Re)Initializes TowerInfo. Call at the beginning and whenever a new \
tower is used. The given options are used in the function CRforDR.\nCall: \
ReInitTower[tower]\nwhere:\n\ttower: An represented by\n\t\
{{x,1,1},{y_1,alpha,0},...,{y_l,alpha_l,0},{p_1,a_1,0},...{p_m,a_m,0},{t_1,1,\
b_1},{t_2,1,b_2},...{t_n,1,b_n}}\n\t(l>=0,m>=0,n>=0, where x,y_i,p_i,t_i are \
the generators and the shift is defined by \[Sigma](p_i)=alpha_i p_i and \
\[Sigma](t_i)= t_i + b_i\n\tThe y_i must be R-monomials, the p_i \
\[CapitalPi]-monomials and the t_i \[CapitalSigma]-monimails.\n\nOptions: \n\
\"SingleSetOfRepresentatives\"->True|False|{pol1,pol2,...pol_k} (Default: \
False) : Whether a single set of Representatives should be used for Rational \
Reduction. This set can be explicitely given as a list of monic, pairwise \
shift-coprime polynomials {pol1,pol2,...pol_k}. The default is that an \
individual set is constructed for each \[CapitalDelta]_f.\n\
\"UseAlwaysIdempotents\"->True|False (Default: False) : Whether Idempotent \
Representation should be used always or only when the tower is not a simple \
tower (default)\n", "Documentation" -> None, "OwnValues" -> None, "UpValues" -> 
    None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, CRforDR`ReInitTower, {CRforDR`ReInitTower[
         PatternTest[
          Pattern[CRforDR`Private`tower, 
           Blank[]], MatrixQ], 
         OptionsPattern[]] :> 
       Module[{CRforDR`Private`newtower, CRforDR`Private`ordList, 
          CRforDR`Private`orders, CRforDR`Private`yList, CRforDR`Private`RExt,
           CRforDR`Private`alphas}, CRforDR`Private`TowerInfo = <||>; 
         If[Head[
             OptionValue["SingleSetOfRepresentatives"]] === List, 
           CRforDR`Private`TowerInfo[
              Part[CRforDR`Private`tower, 1, 1]] = Map[{#, "=="}& , 
              OptionValue["SingleSetOfRepresentatives"]]; 
           CRforDR`Private`TowerInfo["SingleSetOfRepresentatives"] = True; 
           Null, CRforDR`Private`TowerInfo["SingleSetOfRepresentatives"] = 
           TrueQ[
             OptionValue["SingleSetOfRepresentatives"]]]; 
         CRforDR`Private`TowerInfo["UseAlwaysIdempotents"] = 
          OptionValue["UseAlwaysIdempotents"]; 
         CRforDR`Private`TowerInfo["Generators"] = Part[CRforDR`Private`tower, 
            Span[1, All], 1]; ReleaseHold[
           MapAt[Unset, 
            Part[
             Select[
              DownValues[CRforDR`Private`MyChangeShiftTower], And[Head[
                 Part[#, 1, 1, 1]] === List, 
               IntegerQ[
                Part[#, 1, 1, 2]]]& ], 
             Span[1, All], 1], {All, 1}]]; 
         CRforDR`Private`newtower = CRforDR`Private`tower; 
         While[True, 
           CRforDR`Private`RExt = 
            Select[CRforDR`Private`newtower, And[Part[#, 3] === 0, 
               RootOfUnityQ[
                Part[#, 2]]]& ]; If[Length[CRforDR`Private`RExt] == 0, 
             Break[]]; CRforDR`Private`yList = Part[CRforDR`Private`RExt, 
              Span[1, All], 1]; 
           CRforDR`Private`orders = Map[CRforDR`Private`MyGetOrderOfUnity, 
              Part[CRforDR`Private`RExt, 
               Span[1, All], 2]]; 
           CRforDR`Private`alphas = 
            Table[Part[CRforDR`Private`RExt, CRforDR`Private`i, 2]^
              Apply[Times, 
                Part[CRforDR`Private`RExt, 
                 Span[1, CRforDR`Private`i - 1], 2]], {CRforDR`Private`i, 
               Length[CRforDR`Private`RExt]}]; CRforDR`Private`MyAssert[Part[
               Union[
                CRforDR`MyTogether[Part[
                   Select[
                   CRforDR`Private`tower, MemberQ[CRforDR`Private`yList, 
                    Part[#, 1]]& ], 
                   Span[1, All], 2]^CRforDR`Private`orders]], 1] === 1]; If[
             Not[
              KeyExistsQ[CRforDR`Private`TowerInfo, "R-Extension"]], 
             CRforDR`Private`TowerInfo["R-Extension"] = {}]; 
           CRforDR`Private`TowerInfo["R-Extension"] = SortBy[
              Join[
               CRforDR`Private`TowerInfo["R-Extension"], 
               
               Transpose[{
                CRforDR`Private`yList, CRforDR`Private`alphas, 
                 CRforDR`Private`orders}]], Part[
               FirstPosition[
                Part[CRforDR`Private`tower, 
                 Span[1, All], 1], 
                Part[#, 1]], 1]& ]; {
             CRforDR`Private`newtower, CRforDR`Private`ordList} = 
            CRforDR`Private`RemoveRMonomials[
             CRforDR`Private`newtower, CRforDR`Private`yList, 0]; 
           CRforDR`Private`MyAssert[
            CRforDR`Private`ordList === CRforDR`Private`orders]; 
           CRforDR`Private`MyAssert[
            Length[CRforDR`Private`newtower] + Length[
                CRforDR`Private`TowerInfo["R-Extension"]] == 
             Length[CRforDR`Private`tower]]; Null]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {
     "SingleSetOfRepresentatives" -> False, "UseAlwaysIdempotents" -> False}, 
    "Attributes" -> {}, "FullName" -> "CRforDR`ReInitTower"|>, 
   False]]], "Output",
 CellChangeTimes->{3.98999928100495*^9, 3.990172250541213*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"1edc75e2-3bd1-4ce3-9cdf-6591f55d671f"]
}, Open  ]],

