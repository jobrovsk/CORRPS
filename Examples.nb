24ef1a95a2c0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"towerK", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", ",", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "k"}], "+", "n"}], 
        RowBox[{"1", "+", "k"}]], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"h", ",", "1", ",", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"k", "+", "1"}], ")"}]}]}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"towerN", "=", 
