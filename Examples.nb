b59bf9895d8f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tower", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y1", ",", 
       RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y2", ",", 
       RowBox[{"-", "y1"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "2", ",", "0"}], "}"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.989997242596301*^9, 3.989997328062788*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"6565bc30-7a88-470a-8adf-e779bad3a9b0"],

