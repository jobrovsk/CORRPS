    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", ",", 
       FractionBox[
        RowBox[{"1", "+", "n"}], 
        RowBox[{"1", "-", "k", "+", "n"}]], ",", "0"}], "}"}]}], "}"}]}], 
  ";"}]}], "Input",
