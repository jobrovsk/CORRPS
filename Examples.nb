Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"(Re)Initializes TowerInfo. Call at the beginning \
and whenever a new tower is used. The given options are used in the function \
CRforDR.\\nCall: ReInitTower[tower]\\nwhere:\\n\\ttower: An represented by\\n\
\\t{{x,1,1},{y_1,alpha,0},...,{y_l,alpha_l,0},{p_1,a_1,0},...{p_m,a_m,0},{t_1,\
1,b_1},{t_2,1,b_2},...{t_n,1,b_n}}\\n\\t(l>=0,m>=0,n>=0, where x,y_i,p_i,t_i \
are the generators and the shift is defined by \[Sigma](p_i)=alpha_i p_i and \
\[Sigma](t_i)= t_i + b_i\\n\\tThe y_i must be R-monomials, the p_i \
\[CapitalPi]-monomials and the t_i \[CapitalSigma]-monimails.\\n\\nOptions: \
\\n\\\"SingleSetOfRepresentatives\\\"->True|False|{pol1,pol2,...pol_k} \
(Default: False) : Whether a single set of Representatives should be used for \
Rational Reduction. This set can be explicitely given as a list of monic, \
pairwise shift-coprime polynomials {pol1,pol2,...pol_k}. The default is that \
an individual set is constructed for each \
\[CapitalDelta]_f.\\n\\\"UseAlwaysIdempotents\\\"->True|False (Default: \
False) : Whether Idempotent Representation should be used always or only when \
the tower is not a simple tower (default)\\n\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"ReInitTower", "[", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`tower_", "?", "MatrixQ"}], ",", 
                    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    "CRforDR`Private`ordList", ",", "CRforDR`Private`orders", 
                    ",", "CRforDR`Private`yList", ",", "CRforDR`Private`RExt",
                     ",", "CRforDR`Private`alphas"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`TowerInfo", "=", 
                    RowBox[{"Association", "[", "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Head", "[", 
                    
                    RowBox[{"OptionValue", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "]"}], "===", 
                    "List"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    RowBox[{"CRforDR`Private`tower", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}],
                     "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"#1", ",", "\"==\""}], "}"}], "&"}], ")"}], "/@", 
                    
                    
                    RowBox[{"OptionValue", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}]}]}], ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "=", "True"}], 
                    ";"}], ",", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "=", 
                    RowBox[{"TrueQ", "[", 
                    
                    RowBox[{"OptionValue", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "]"}]}]}], "]"}],
                     ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"UseAlwaysIdempotents\"", "]"}], "=", 
                    
                    RowBox[{"OptionValue", "[", "\"UseAlwaysIdempotents\"", 
                    "]"}]}], ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"Generators\"", "]"}], "=", 
                    RowBox[{"CRforDR`Private`tower", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}]}], ";", 
                    RowBox[{"ReleaseHold", "[", 
                    RowBox[{"MapAt", "[", 
                    RowBox[{"Unset", ",", 
                    RowBox[{
                    RowBox[{"Select", "[", 
                    RowBox[{
                    
                    RowBox[{"DownValues", "[", 
                    "CRforDR`Private`MyChangeShiftTower", "]"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"Head", "[", 
                    RowBox[{"#1", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ",", "1", ",", "1"}], 
                    "\[RightDoubleBracket]"}], "]"}], "===", "List"}], "&&", 
                    RowBox[{"IntegerQ", "[", 
                    RowBox[{"#1", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ",", "1", ",", "2"}], 
                    "\[RightDoubleBracket]"}], "]"}]}], "&"}]}], "]"}], 
                    "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"All", ",", "1"}], "}"}]}], "]"}], "]"}], ";", 
                    
                    RowBox[{"CRforDR`Private`newtower", "=", 
                    "CRforDR`Private`tower"}], ";", 
                    RowBox[{"While", "[", 
                    RowBox[{"True", ",", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`RExt", "=", 
                    RowBox[{"Select", "[", 
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "3", 
                    "\[RightDoubleBracket]"}], "===", "0"}], "&&", 
                    RowBox[{"RootOfUnityQ", "[", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}], "]"}]}], "&"}]}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "CRforDR`Private`RExt", "]"}], 
                    "\[Equal]", "0"}], ",", 
                    RowBox[{"Break", "[", "]"}]}], "]"}], ";", 
                    RowBox[{"CRforDR`Private`yList", "=", 
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}]}], ";", 
                    RowBox[{"CRforDR`Private`orders", "=", 
                    RowBox[{"CRforDR`Private`MyGetOrderOfUnity", "/@", 
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "2"}], 
                    "\[RightDoubleBracket]"}]}]}], ";", 
                    RowBox[{"CRforDR`Private`alphas", "=", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    SuperscriptBox[
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{"CRforDR`Private`i", ",", "2"}], 
                    "\[RightDoubleBracket]"}], 
                    RowBox[{"Times", "@@", 
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", 
                    RowBox[{"CRforDR`Private`i", "-", "1"}]}], ",", "2"}], 
                    "\[RightDoubleBracket]"}]}]], ",", 
                    RowBox[{"{", 
                    RowBox[{"CRforDR`Private`i", ",", 
                    RowBox[{"Length", "[", "CRforDR`Private`RExt", "]"}]}], 
                    "}"}]}], "]"}]}], ";", 
                    RowBox[{"CRforDR`Private`MyAssert", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Union", "[", 
                    RowBox[{"MyTogether", "[", 
                    SuperscriptBox[
                    RowBox[{
                    RowBox[{"Select", "[", 
                    RowBox[{"CRforDR`Private`tower", ",", 
                    RowBox[{
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"CRforDR`Private`yList", ",", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}]}], "]"}], "&"}]}], "]"}], 
                    "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "2"}], 
                    "\[RightDoubleBracket]"}], "CRforDR`Private`orders"], 
                    "]"}], "]"}], "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "===", "1"}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"KeyExistsQ", "[", 
                    
                    RowBox[{"CRforDR`Private`TowerInfo", ",", 
                    "\"R-Extension\""}], "]"}]}], ",", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], "=", 
                    RowBox[{"{", "}"}]}]}], "]"}], ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], "=", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{
                    RowBox[{"Join", "[", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], ",", 
                    RowBox[{"Transpose", "[", 
                    RowBox[{"{", 
                    
                    RowBox[{"CRforDR`Private`yList", ",", 
                    "CRforDR`Private`alphas", ",", "CRforDR`Private`orders"}],
                     "}"}], "]"}]}], "]"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"FirstPosition", "[", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`tower", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}], ",", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}]}], "]"}], 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    "&"}]}], "]"}]}], ";", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    "CRforDR`Private`ordList"}], "}"}], "=", 
                    RowBox[{"CRforDR`Private`RemoveRMonomials", "[", 
                    
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    "CRforDR`Private`yList", ",", "0"}], "]"}]}], ";", 
                    RowBox[{"CRforDR`Private`MyAssert", "[", 
                    
                    RowBox[{"CRforDR`Private`ordList", "===", 
                    "CRforDR`Private`orders"}], "]"}], ";", 
                    RowBox[{"CRforDR`Private`MyAssert", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "CRforDR`Private`newtower", "]"}], 
                    "+", 
                    RowBox[{"Length", "[", 
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], "]"}]}], "\[Equal]", 
                    RowBox[{"Length", "[", "CRforDR`Private`tower", "]"}]}], 
                    "]"}], ";"}]}], "]"}]}]}], "]"}]}]}, {" "}}, 
                  GridBoxAlignment -> {"Columns" -> {{Left}}}, 
                  DefaultBaseStyle -> "Column", 
                  GridBoxItemSize -> {
                   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]},
