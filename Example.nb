              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"ReInitTower", "[", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`tower_", "?", "MatrixQ"}], ",", 
                    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    "CRforDR`Private`ordList", ",", "CRforDR`Private`orders", 
                    ",", "CRforDR`Private`yList", ",", "CRforDR`Private`RExt",
                     ",", "CRforDR`Private`alphas"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`TowerInfo", "=", 
                    RowBox[{"Association", "[", "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Head", "[", 
                    
                    RowBox[{"OptionValue", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "]"}], "===", 
                    "List"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    RowBox[{"CRforDR`Private`tower", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "]"}],
                     "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"#1", ",", "\"==\""}], "}"}], "&"}], ")"}], "/@", 
                    
                    
                    RowBox[{"OptionValue", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}]}]}], ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "=", "True"}], 
                    ";"}], ",", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "=", 
                    RowBox[{"TrueQ", "[", 
                    
                    RowBox[{"OptionValue", "[", 
                    "\"SingleSetOfRepresentatives\"", "]"}], "]"}]}]}], "]"}],
                     ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"UseAlwaysIdempotents\"", "]"}], "=", 
                    
                    RowBox[{"OptionValue", "[", "\"UseAlwaysIdempotents\"", 
                    "]"}]}], ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"Generators\"", "]"}], "=", 
                    RowBox[{"CRforDR`Private`tower", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}]}], ";", 
                    RowBox[{"ReleaseHold", "[", 
                    RowBox[{"MapAt", "[", 
                    RowBox[{"Unset", ",", 
                    RowBox[{
                    RowBox[{"Select", "[", 
                    RowBox[{
                    RowBox[{"DownValues", "[", "MyChangeShiftTower", "]"}], 
                    ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"Head", "[", 
                    RowBox[{"#1", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ",", "1", ",", "1"}], 
                    "\[RightDoubleBracket]"}], "]"}], "===", "List"}], "&&", 
                    RowBox[{"IntegerQ", "[", 
                    RowBox[{"#1", "\[LeftDoubleBracket]", 
                    RowBox[{"1", ",", "1", ",", "2"}], 
                    "\[RightDoubleBracket]"}], "]"}]}], "&"}]}], "]"}], 
                    "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"All", ",", "1"}], "}"}]}], "]"}], "]"}], ";", 
                    
                    RowBox[{"CRforDR`Private`newtower", "=", 
                    "CRforDR`Private`tower"}], ";", 
                    RowBox[{"While", "[", 
                    RowBox[{"True", ",", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`RExt", "=", 
                    RowBox[{"Select", "[", 
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "3", 
                    "\[RightDoubleBracket]"}], "===", "0"}], "&&", 
                    RowBox[{"RootOfUnityQ", "[", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}], "]"}]}], "&"}]}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "CRforDR`Private`RExt", "]"}], 
                    "\[Equal]", "0"}], ",", 
                    RowBox[{"Break", "[", "]"}]}], "]"}], ";", 
                    RowBox[{"CRforDR`Private`yList", "=", 
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}]}], ";", 
                    RowBox[{"CRforDR`Private`orders", "=", 
                    RowBox[{"CRforDR`Private`MyGetOrderOfUnity", "/@", 
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "2"}], 
                    "\[RightDoubleBracket]"}]}]}], ";", 
                    RowBox[{"CRforDR`Private`alphas", "=", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    SuperscriptBox[
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{"CRforDR`Private`i", ",", "2"}], 
                    "\[RightDoubleBracket]"}], 
                    RowBox[{"Times", "@@", 
                    RowBox[{"CRforDR`Private`RExt", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", 
                    RowBox[{"CRforDR`Private`i", "-", "1"}]}], ",", "2"}], 
                    "\[RightDoubleBracket]"}]}]], ",", 
                    RowBox[{"{", 
                    RowBox[{"CRforDR`Private`i", ",", 
                    RowBox[{"Length", "[", "CRforDR`Private`RExt", "]"}]}], 
                    "}"}]}], "]"}]}], ";", 
                    RowBox[{"Assert", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"Union", "[", 
                    RowBox[{"MyTogether", "[", 
                    SuperscriptBox[
                    RowBox[{
                    RowBox[{"Select", "[", 
                    RowBox[{"CRforDR`Private`tower", ",", 
                    RowBox[{
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"CRforDR`Private`yList", ",", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}]}], "]"}], "&"}]}], "]"}], 
                    "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "2"}], 
                    "\[RightDoubleBracket]"}], "CRforDR`Private`orders"], 
                    "]"}], "]"}], "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "===", "1"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"167", ",", 
                    "\"RPiSigmaRingReduction/CRforDR.m\""}], "}"}]}], "]"}], 
                    ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"KeyExistsQ", "[", 
                    
                    RowBox[{"CRforDR`Private`TowerInfo", ",", 
                    "\"R-Extension\""}], "]"}]}], ",", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], "=", 
                    RowBox[{"{", "}"}]}]}], "]"}], ";", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], "=", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{
                    RowBox[{"Join", "[", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], ",", 
                    RowBox[{"Transpose", "[", 
                    RowBox[{"{", 
                    
                    RowBox[{"CRforDR`Private`yList", ",", 
                    "CRforDR`Private`alphas", ",", "CRforDR`Private`orders"}],
                     "}"}], "]"}]}], "]"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"FirstPosition", "[", 
                    RowBox[{
                    RowBox[{"CRforDR`Private`tower", "\[LeftDoubleBracket]", 
                    RowBox[{
                    RowBox[{"1", ";;", "All"}], ",", "1"}], 
                    "\[RightDoubleBracket]"}], ",", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}]}], "]"}], 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    "&"}]}], "]"}]}], ";", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    "CRforDR`Private`ordList"}], "}"}], "=", 
                    RowBox[{"CRforDR`Private`RemoveRMonomials", "[", 
                    
                    RowBox[{"CRforDR`Private`newtower", ",", 
                    "CRforDR`Private`yList", ",", "0"}], "]"}]}], ";", 
                    RowBox[{"Assert", "[", 
                    RowBox[{
                    
                    RowBox[{"CRforDR`Private`ordList", "===", 
                    "CRforDR`Private`orders"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"172", ",", 
                    "\"RPiSigmaRingReduction/CRforDR.m\""}], "}"}]}], "]"}], 
                    ";", 
                    RowBox[{"Assert", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "CRforDR`Private`newtower", "]"}], 
                    "+", 
                    RowBox[{"Length", "[", 
                    RowBox[{"CRforDR`Private`TowerInfo", "[", 
                    "\"R-Extension\"", "]"}], "]"}]}], "\[Equal]", 
                    RowBox[{"Length", "[", "CRforDR`Private`tower", "]"}]}], 
                    ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"173", ",", 
                    "\"RPiSigmaRingReduction/CRforDR.m\""}], "}"}]}], "]"}], 
                    ";"}]}], "]"}]}]}], "]"}]}]}, {" "}}, 
