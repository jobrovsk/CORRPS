Cell["Example 2 (\[OpenCurlyDoubleQuote]general\[CloseCurlyDoubleQuote] R\
\[CapitalPi]\[CapitalSigma]*-extension)", "Subsection",
 CellChangeTimes->{{3.9899971411152697`*^9, 3.989997143226625*^9}, {
   3.98999944250353*^9, 3.989999448818342*^9}, 
   3.98999953434402*^9},ExpressionUUID->"319b3c6f-0824-405c-95a5-\
fa34c8c57c6b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tower", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"p1", ",", "2", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"p2", ",", 
       RowBox[{"x", "+", "1"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"p3", ",", 
       FractionBox[
        RowBox[{"x", "+", "3", "-", 
         RowBox[{"y", 
          RowBox[{"(", 
           RowBox[{"x", "-", "1"}], ")"}]}]}], "4"], ",", "0"}], "}"}]}], 
    "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.989999539539476*^9, 3.989999604506075*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"2c78ba0b-e5bf-456b-b2a9-799fc093c4bb"],

Cell[BoxData[
 RowBox[{"ReInitTower", "[", "tower", "]"}]], "Input",
 CellChangeTimes->{{3.989999618238166*^9, 3.9899996186253967`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"027319b9-f2b9-40a2-9844-5aee6466da74"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"y", 
        RowBox[{"(", 
         RowBox[{"2", "-", "x"}], ")"}]}], "+", "x"}], ")"}], "p2"}], 
    RowBox[{"p1", " ", "p3"}]]}], " ", ";"}]], "Input",
 CellChangeTimes->{{3.989999639105432*^9, 3.989999661034281*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"30f6a043-f517-41fb-82ba-4abbaf0719d5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CRforDR", "[", 
  RowBox[{"f", ",", "tower"}], "]"}]], "Input",
 CellChangeTimes->{3.9899996672139072`*^9},
 CellLabel->"In[28]:=",ExpressionUUID->"ba28c124-aa0d-44b5-8247-afda1718ad2c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"2", " ", "p2", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "y"}], ")"}]}], 
     RowBox[{"p1", " ", "p3", " ", "x"}]], "+", 
    FractionBox[
     RowBox[{"4", " ", "p2", " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", "y"}], ")"}]}], 
     RowBox[{"p1", " ", "p3", " ", 
      RowBox[{"(", 
       RowBox[{"3", "+", "x", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "y"}]}], ")"}]}]], "+", 
    FractionBox[
     RowBox[{"p2", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "y"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "x", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"3", "-", "x"}], ")"}], " ", "y"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"2", "+", "x", "-", 
        RowBox[{"2", " ", "y"}], "+", 
        RowBox[{"x", " ", "y"}]}], ")"}]}], 
     RowBox[{"4", " ", "p1", " ", "p3", " ", "x"}]]}], ",", "0"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.98999966802496*^9},
 CellLabel->"Out[28]=",ExpressionUUID->"52de0ee6-337d-415f-8c81-2e319f131d22"]
}, Open  ]],

